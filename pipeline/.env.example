# Copy to .env (same folder) and fill in. .env is gitignored — never commit tokens.
# Telegram: make a bot via @BotFather, then get the chat/channel id.
TG_BOT_TOKEN=123456:ABC-your-bot-token
TG_CHAT_ID=-1001234567890        # your channel/chat id (negative for channels)

# Model + window (optional overrides)
RADAR_MODEL=gemma3:12b-it-qat    # or gpt-oss:20b (installed), gemma3:27b-it-qat (slow), gemma3:4b-it-qat (fast/weak)
RADAR_DAYS=7
